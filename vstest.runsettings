<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
	<!-- Force test host architecture to x64 to avoid missing x86 dotnet host in CI environment -->
	<TargetPlatform>x64</TargetPlatform>
	<TargetFrameworkVersion>net10.0</TargetFrameworkVersion>
  </RunConfiguration>
</RunSettings>
